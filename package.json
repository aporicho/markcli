{
  "name": "markcli",
  "version": "1.0.0",
  "description": "终端 Markdown 批注工具",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "markcli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --write",
    "build:binary": "node scripts/build-binary.mjs",
    "build:binary:all": "node scripts/build-binary.mjs --all"
  },
  "keywords": [
    "markdown",
    "cli",
    "annotation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "approx-string-match": "^2.0.0",
    "chalk": "^5.6.2",
    "cli-markdown": "^3.5.1",
    "ink": "^6.8.0",
    "markdown-it": "^14.1.1",
    "markdown-it-terminal": "^0.4.0",
    "markdown-to-ansi": "^1.0.0",
    "meow": "^14.1.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "string-width": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
